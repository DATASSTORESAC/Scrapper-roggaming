# ═══════════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL SCRAPER
# ═══════════════════════════════════════════════════════════════

# Proveedor a ejecutar (opcional - si no se especifica, ejecuta todos)
# Valores: caleta, pcmaster, o el ID numérico
SUPPLIER_CODE=caleta
# SUPPLIER_ID=1

# API Laravel
API_URL=http://localhost:8000/api
API_TOKEN=your-scraper-token-here  # Must match SCRAPER_TOKEN in backend .env

# Puppeteer
HEADLESS=true
TIMEOUT_MS=60000
MAX_RETRIES=3
CONCURRENCY=1

# CI Mode (se activa automáticamente en GitHub Actions)
# CI=true